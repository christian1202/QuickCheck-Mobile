{
  "expo": {
    "name": "QuickCheck",
    "slug": "quickcheck-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "backgroundColor": "#f8f9ff",
      "image": "./assets/icon.png",
      "resizeMode": "contain"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.quickcheck.mobile"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#f8f9ff"
      },
      "package": "com.quickcheck.mobile"
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-font",
      "@react-native-google-signin/google-signin"
    ],
    "extra": {
      "eas": {
        "projectId": "a9c9e171-ed6f-423c-aed3-3a3c9e972881"
      }
    }
  }
}
