# ============================================================
# QuickCheck — Environment Variables
# ============================================================
# Copy this to .env and fill in your values.
# NEVER commit .env to version control!
# ============================================================

# ─── Supabase (Frontend / Expo) ──────────────────────────
EXPO_PUBLIC_SUPABASE_URL=https://rjfqjfkinuoqxagkbzlo.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here

# ─── Cloudflare R2 (Edge Function secrets) ───────────────
# Set these as Supabase secrets, NOT in .env:
#   supabase secrets set R2_ACCOUNT_ID=your_account_id
#   supabase secrets set R2_BUCKET=quickcheck-mobile
#   supabase secrets set R2_PUBLIC_URL=https://your-public-url.r2.dev
#   supabase secrets set R2_ACCESS_KEY_ID=your_access_key_id
#   supabase secrets set R2_SECRET_ACCESS_KEY=your_secret_access_key
